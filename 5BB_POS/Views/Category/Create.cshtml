@using _5BB_POS.RequestModels
@model CategoryRequestModel

@{
    ViewData["Title"] = "Create Category";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-5 mx-auto">
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white p-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-tag-fill me-2"></i>Create New Category
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="StoreCategory" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label asp-for="name" class="form-label fw-bold">Category Name</label>
                            <input asp-for="name" class="form-control form-control-lg"
                                   placeholder="e.g. Beverages, Electronics..." required />
                            <div class="form-text">Provide a unique name for this category.</div>
                            <span class="text-danger small" asp-validation-for="name"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-1"></i> Save Category
                            </button>
                            <a asp-action="Index" class="btn btn-light border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}